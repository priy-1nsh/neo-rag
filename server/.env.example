# --- Database ---------------------------------------------------------------
# A Postgres connection string. Use a free Neon database (https://neon.tech) —
# it ships with the pgvector extension already available.
# Example: postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Force SSL on/off. Leave blank to auto-detect (SSL on in production / managed DBs).
DATABASE_SSL=

# --- OpenAI -----------------------------------------------------------------
# Leave BLANK to run in offline MOCK mode (no credits spent — embeddings and
# answers are generated locally so the whole pipeline still works for demos).
# Paste a real key to switch to live OpenAI with zero code changes.
OPENAI_API_KEY=

# Models (defaults match the Scrimba AI Engineering pathway)
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Server -----------------------------------------------------------------
PORT=3001
